# =====================================================================
# LifeOS – Miljøvariabler (eksempel)
# ---------------------------------------------------------------------
# Kopiér denne fil til ".env.local" og indsæt dine rigtige nøgler der.
# .env.local bliver IKKE delt på git (den er hemmelig).
#
# I Fase 2 er alle værdier PLADSHOLDERE. Intet er koblet på endnu.
# =====================================================================

# ---------- App-URL (til bekræftelses- og nulstillingslinks i e-mails) ----------
# Lokalt: http://localhost:3000 . I produktion: din rigtige adresse (uden / til sidst).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Supabase (database + login) ----------
# Bemærk: "NEXT_PUBLIC_" betyder, at variablen er sikker at bruge i browseren.
# Disse to ER ment til browseren (det er sådan Supabase fungerer).
# Så snart de rigtige værdier står her, slår login og rute-beskyttelse til.
NEXT_PUBLIC_SUPABASE_URL=din-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=din-supabase-anon-key
# Service role-nøglen er HEMMELIG og må kun bruges på serveren – aldrig i browseren.
SUPABASE_SERVICE_ROLE_KEY=din-supabase-service-role-key

# ---------- LifeOS-ejer (version 1 = én bruger) ----------
# Den primære bruger. Hardcodes ALDRIG i koden – kun her i miljøvariabler.
OWNER_EMAIL=lassebrandtchr@gmail.com

# ---------- AI-modeller ----------
OPENAI_API_KEY=din-openai-api-key
ANTHROPIC_API_KEY=din-anthropic-api-key

# ---------- Google (mail + kalender) ----------
GOOGLE_CLIENT_ID=din-google-client-id
GOOGLE_CLIENT_SECRET=din-google-client-secret

# ---------- Microsoft Outlook (mail + kalender) ----------
# Oprettes i Azure Portal → "App registrations". Redirect URI skal være
# <NEXT_PUBLIC_SITE_URL>/api/integrations/microsoft/callback
OUTLOOK_CLIENT_ID=din-outlook-client-id
OUTLOOK_CLIENT_SECRET=din-outlook-client-secret

# ---------- Automatisk synk (cron) ----------
# Hemmelig nøgle, så kun Vercel Cron må starte baggrunds-synken hver 30. min.
# Sæt en lang tilfældig streng (fx fra en password-generator).
CRON_SECRET=din-lange-tilfaeldige-cron-hemmelighed

# ---------- Notion ----------
NOTION_API_KEY=din-notion-api-key

# ---------- Sociale medier / markedsføring ----------
FACEBOOK_APP_ID=din-facebook-app-id
INSTAGRAM_APP_ID=din-instagram-app-id
TIKTOK_API_KEY=din-tiktok-api-key

# ---------- Video / AI-medier ----------
HIGGSFIELD_API_KEY=din-higgsfield-api-key
